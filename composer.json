{
    "name": "versionist/laravel-api-versionist",
    "description": "Elegant API versioning for Laravel — transform requests and responses across versions automatically.",
    "keywords": ["laravel", "api", "versioning", "transformer", "rest"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Jay Anta",
            "email": "jay123anta@gmail.com",
            "homepage": "https://github.com/jay123anta"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Versionist\\ApiVersionist\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Versionist\\ApiVersionist\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Versionist\\ApiVersionist\\ApiVersionistServiceProvider"
            ],
            "aliases": {
                "ApiVersionist": "Versionist\\ApiVersionist\\Facades\\ApiVersionist"
            }
        }
    }
}
